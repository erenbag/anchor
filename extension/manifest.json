{
  "manifest_version": 3,
  "name": "Anchor — Clickbait Dedektörü",
  "version": "1.0.0",
  "description": "Başlık-İçerik uyuşmazlığını tespit eden akıllı clickbait analiz uzantısı.",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "*://*.youtube.com/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles/anchor-ring.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
